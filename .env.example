# ITSM Modern AI - configuration (.env)
#
# Pas de secrets ici : la cle LLM et les tokens GLPI se saisissent dans l'UI
# (chiffres au repos). .env ne porte que des reglages non-secrets + la master key.
# Options avancees (PostgreSQL, GLPI API v2, metriques, anti-SSRF, reverse proxy) :
# https://docs.itsm-modern-ai.com

# --- Persistance ---
DATABASE_URL=sqlite:///./data/itsm.db

# --- Chiffrement des secrets au repos ---
# Cle Fernet ; si vide, generee et persistee dans data/master.key au 1er demarrage.
MASTER_KEY=

# --- Amorcage admin (deploiement orchestrateur / non-interactif) ---
# Si defini, le compte admin est amorce AU PREMIER BOOT par l'entrypoint (idempotent :
# ignore si deja configure, jamais ecrase). Minimum 8 caracteres. Retirable apres le
# 1er demarrage (le hash est persiste chiffre dans le volume). Vide = pas d'amorcage
# automatique (mot de passe demande par install.sh, ou via curl|bash interactif).
# Alias accepte : ADMIN_PASSWORD (meme effet).
# ITSM_ADMIN_PASSWORD=

# --- LLM (defauts ; aussi modifiables dans l'UI) ---
# Souverain par defaut : Mistral EU. Autres : openai | ollama | anthropic.
LLM_BASE_URL=https://api.mistral.ai/v1
LLM_MODEL=mistral-large-latest

# --- Moteur a garde-fous ---
CONFIDENCE_THRESHOLD=0.7
COST_CAP_EUR_PER_DAY=5.0

# --- GLPI (base_url non-secret ; les tokens se poussent via l'UI) ---
GLPI_BASE_URL=
GLPI_VERIFY_TLS=true
# On-premise : le GLPI est presque toujours sur IP/hostname PRIVE (RFC1918, .local,
# loopback). Ce flag (defaut true) autorise une cible privee pour les SEULS clients GLPI
# (le garde anti-SSRF reste strict pour le LLM et l'update-check). Passer a false uniquement
# si votre GLPI est expose sur une URL publique et que vous voulez le durcissement complet.
GLPI_ALLOW_PRIVATE=true

# --- Polling ---
POLLING_ENABLED=true
POLLING_INTERVAL_SECONDS=60
POLLING_MAX_TICKETS=200

# --- Session ---
# Cookie Secure. Defaut false (pilote HTTP) ; repasser a true derriere un TLS.
SESSION_HTTPS_ONLY=false

# --- Supporter (optionnel) ---
# Les fonctions Supporter sont livrees mais verrouillees : coller la cle dans la
# page Supporter de la console (Ed25519, verifiee hors-ligne). Ligne ci-dessous =
# pre-amorcage optionnel pour les deploiements automatises ; vide = Community.
# LICENSE_KEY=itsm-lic.v1.xxx

# --- Verification de mise a jour ---
# Activee par defaut (best-effort, lit seulement le dernier numero de version publie,
# aucune donnee envoyee). Air-gap / 100% hors-ligne : decommentez la ligne ci-dessous
# (valeur vide = desactive).
# UPDATE_CHECK_URL=
